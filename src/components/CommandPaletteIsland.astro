---
import CommandPalette from "./CommandPalette";
import { TAGS } from "../types";
import { getVisiblePosts } from "../utils";

const posts = await getVisiblePosts();

const items = [
  { kind: "page", title: "Home", href: "/", excerpt: "Latest essays" },
  { kind: "page", title: "Archive", href: "/archive/", excerpt: "All posts by year" },
  { kind: "page", title: "Tags", href: "/tags/", excerpt: "Filter by topic" },
  { kind: "page", title: "About", href: "/about/", excerpt: "Who writes this" },
  { kind: "page", title: "Colophon", href: "/colophon/", excerpt: "How this site is built" },
  ...posts.map((p) => ({
    kind: "essay",
    title: p.data.title,
    href: `/p/${p.id}/`,
    excerpt: p.data.excerpt,
    hay: `${p.data.title} ${p.data.excerpt} ${p.data.tag}`.toLowerCase(),
  })),
  ...TAGS.map((t) => ({
    kind: "tag",
    title: `#${t}`,
    href: `/tags/${t}/`,
    excerpt: "Filter by tag",
    hay: t,
  })),
];
---

<CommandPalette client:load items={items} />

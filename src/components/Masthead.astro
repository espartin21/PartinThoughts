---
import { META } from "../types";

interface Props {
  activeNav?: string;
}

const { activeNav = "" } = Astro.props;
---

<header class="mast">
  <div class="shell">
    <div class="mast-row">
      <a href="/" class="mark" aria-label="Partin Thoughts — home">
        <span class="mark-dot"></span>
        <span>Partin Thoughts</span>
        <span class="mark-sub">est. {META.since}</span>
      </a>
      <nav class="nav" aria-label="Primary">
        <a href="/archive/" class="nav-link" data-active={activeNav === "archive"}>Archive</a>
        <a href="/tags/" class="nav-link" data-active={activeNav === "tags"}>Tags</a>
        <a href="/about/" class="nav-link" data-active={activeNav === "about"}>About</a>
        <button class="searchbtn" data-open-palette aria-label="Open search">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="11" cy="11" r="7"></circle><path d="m20 20-3.5-3.5"></path>
          </svg>
          <span>Search</span>
          <kbd>&#8984;K</kbd>
        </button>
        <button class="iconbtn" data-theme-toggle aria-label="Toggle theme">
          <svg
            class="icon-moon"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
          </svg>
          <svg
            class="icon-sun"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            style="display:none;"
          >
            <circle cx="12" cy="12" r="4"></circle><path
              d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"
            ></path>
          </svg>
        </button>
      </nav>
    </div>
  </div>
</header>

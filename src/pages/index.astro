---
import Base from "../layouts/Base.astro";
import PostList from "../components/PostList.astro";
import { META } from "../types";
import { getVisiblePosts, readTime } from "../utils";

const posts = await getVisiblePosts();

const featured = posts[0];
const rest = posts.slice(1, 9);

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });

const featuredRead = readTime(featured.body);

const restEntries = rest.map((p) => ({
  id: p.id,
  title: p.data.title,
  dateLabel: fmt(p.data.date),
  tag: p.data.tag,
  readTime: readTime(p.body),
}));
---

<Base>
  <main id="main" class="page">
    <section class="hero">
      <div class="shell">
        <div class="hero-eyebrow">Essays &middot; Wisdom &middot; Observations</div>
        <!-- Alt: Parting thoughts, <em>said once</em>, on the things worth saying twice. -->
        <!-- Alt: Parting thoughts, <em>shared slowly</em>, on things that don't need to be rushed. -->
        <h1 class="hero-h">
          Parting thoughts, <em>said aloud</em>, on the things that usually stay quiet.
        </h1>
        <p class="hero-sub">{META.bio} Updated irregularly, read at your leisure.</p>
      </div>
    </section>

    <section class="featured">
      <div class="shell">
        <a href={`/p/${featured.id}/`} class="featured-card" data-preview-slug={featured.id}>
          <div class="featured-meta">
            <span>Featured &middot; {fmt(featured.data.date)}</span>
            <span class="tag">{featured.data.tag} &middot; {featuredRead} min</span>
          </div>
          <h2 class="featured-h">{featured.data.title}</h2>
          <p class="featured-dek">{featured.data.excerpt}</p>
        </a>
      </div>
    </section>

    {
      rest.length > 0 && (
        <section class="feed">
          <div class="shell">
            <div class="feed-head">
              <span>Recent</span>
              <a href="/archive/">All posts &rarr;</a>
            </div>
            <PostList posts={restEntries} />
          </div>
        </section>
      )
    }
  </main>
</Base>
